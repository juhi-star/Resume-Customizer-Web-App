# Get a free Groq API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use (llama-3.3-70b-versatile recommended)
GROQ_MODEL=llama-3.3-70b-versatile

# JWT secret - use a long random string in production
JWT_SECRET_KEY=tailor-dev-secret-change-in-production

# CORS - comma separated list of allowed origins
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Database URL (optional, defaults to SQLite tailor.db)
# DATABASE_URL=sqlite:///./tailor.db
